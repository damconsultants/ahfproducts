                <field id="alis_bt_id_1" translate="label" type="button" sortOrder="6" showInDefault="1" showInWebsite="1" showInStore="3">
                    <frontend_model>DamConsultants\Ahfproducts\Block\System\Config\SyncAliasButton</frontend_model>
                </field>

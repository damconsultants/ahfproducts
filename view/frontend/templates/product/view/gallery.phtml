/**
 * Product media data template
 *
 * @var $block \Magento\Catalog\Block\Product\View\Gallery
 */
?>

<?php
$bynderImage = $block->getProduct()->getBynderMultiImg();
$imageTypes = [];
$hasVideo = false;

if (!empty($bynderImage)) {
    $jsonDecoded = json_decode($bynderImage, true);
    
    if (is_array($jsonDecoded)) {
        // Handle the nested JSON structure where each SKU has its own array of images
        foreach ($jsonDecoded as $sku => $imagesData) {
            if (is_array($imagesData)) {
                foreach ($imagesData as $imageData) {
                    if (isset($imageData['item_type'])) {
                        $imageTypes[] = $imageData['item_type'];
                        if ($imageData['item_type'] === 'VIDEO') {
                            $hasVideo = true;
                        }
                    }
                }
            }
        }
    }
}

$images = $block->getGalleryImages()->getItems();
$mainImage = current(array_filter($images, function ($img) use ($block) {
    return $block->isMainImage($img);
}));

if (!empty($images) && empty($mainImage)) {
    $mainImage = $block->getGalleryImages()->getFirstItem();
}

$helper = $block->getData('imageHelper');
$mainImageData = $mainImage ?
    $mainImage->getData('medium_image_url') :
    $helper->getDefaultPlaceholderUrl('image');

$imgUrl = $mainImageData;
$singleImage = $block->getSingleImage();
if (!empty($singleImage) && $singleImage != '0') {
    $imgUrl = $singleImage;
}

// Get all image data from gallery JSON for proper video detection
$galleryImagesJson = $block->getGalleryImagesJson();
$galleryData = json_decode($galleryImagesJson, true);
$hasVideoInGallery = false;

if (is_array($galleryData)) {
    foreach ($galleryData as $image) {
        if (isset($image['type']) && $image['type'] === 'video') {
            $hasVideoInGallery = true;
            break;
        }
    }
}

$imageTypesJson = json_encode(array_unique($imageTypes));
?>

<div class="gallery-placeholder _block-content-loading" data-gallery-role="gallery-placeholder">
    <img alt="main product photo" class="gallery-placeholder__image"
        src="<?= /* @noEscape */ $imgUrl ?>" />
</div>

<script type="text/x-magento-init">
    {
        "[data-gallery-role=gallery-placeholder]": {
            "mage/gallery/gallery": {
                "mixins":["magnifier/magnify"],
                "magnifierOpts": <?= /* @noEscape */ $block->getMagnifier() ?>,
                "data": <?= /* @noEscape */ $galleryImagesJson ?>,
                "options": <?= /* @noEscape */ $block->getGalleryOptions()->getOptionsJson() ?>,
                "fullscreen": <?= /* @noEscape */ $block->getGalleryOptions()->getFSOptionsJson() ?>,
                "breakpoints": <?= /* @noEscape */ $block->getBreakpoints() ?>
            }
        }
    }
</script>

<style>
    #video-tag {
        margin: 50px;
        padding: 100px 0px 152px;
        height: 450px;
        background: #000;
        max-width: 100%;
    }
    
    .video_control {
        opacity: 0.5;
        cursor: pointer;
    }
    
    .video-thumb-icon .fotorama__thumb {
        position: relative;
    }
    
    .video-thumb-icon .fotorama__thumb:after {
        content: "▶";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: #fff;
        font-size: 24px;
        background: rgba(0,0,0,0.6);
        border-radius: 50%;
        width: 40px;
        height: 40px;
        line-height: 40px;
        text-align: center;
    }
    
    .fotorama-video-container {
        position: relative;
        background: #000;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .fotorama-video-container video {
        display: block;
        margin: 0 auto;
        max-width: 100%;
        max-height: 100%;
    }
    .fotorama__nav-wrap .fotorama_horizontal_ratio .fotorama__img {
        width: 155px !important;
    }
</style>

<script>
    require(['jquery', 'domReady!'], function ($) {
        'use strict';

        var hasVideo = <?= $hasVideoInGallery ? 'true' : 'false' ?>;
        var isVideoInitialized = false;

        function initializeVideoGallery() {
            if (!hasVideo || isVideoInitialized) {
                return;
            }

            var $gallery = $('div.gallery-placeholder');
            var $fotorama = $gallery.find('> div.fotorama');
            
            if (!$fotorama.length) {
                setTimeout(initializeVideoGallery, 500);
                return;
            }

            var fotorama = $fotorama.data('fotorama');
            if (!fotorama) {
                setTimeout(initializeVideoGallery, 500);
                return;
            }

            // Handle video frames on load
            $fotorama.off('fotorama:load.video').on('fotorama:load.video', function (e, fotoramaObj, extra) {
                if (extra.frame && extra.frame.type === 'iframe') {
                    // Add video thumbnail indicator
                    setTimeout(function () {
                        $('.fotorama__nav__frame img[src="' + extra.frame.thumb + '"]')
                            .closest('.fotorama__nav__frame')
                            .addClass('video-thumb-icon');
                    }, 100);

                    // Create video element
                    var videoHtml = '<div class="fotorama-video-container video-unplayed video_control">' +
                        '<video id="video-tag" width="75%" playsinline preload="metadata" controls="false">' +
                        '<source src="' + extra.frame.src + '" type="video/mp4">' +
                        'Your browser does not support the video tag.' +
                        '</video></div>';
                    
                    extra.frame.$stageFrame.html(videoHtml);
                    
                    // Set initial state
                    extra.frame.$stageFrame.find('.video_control').css('opacity', '0.5');
                }
            });

            // Handle navigation clicks (arrows and thumbnails)
            $fotorama.off('click.videoNav').on('click.videoNav', '.fotorama__arr, .fotorama__nav__shaft', function () {
                var $activeFrame = $('.fotorama__active');
                var videoTag = $activeFrame.find('#video-tag').get(0);
                
                if (videoTag) {
                    videoTag.pause();
                    videoTag.currentTime = 0;
                    videoTag.removeAttribute('controls');
                }
                
                $activeFrame.find('.video_control')
                    .addClass("fotorama-video-container")
                    .css("opacity", "0.5");
            });

            // Handle video play/pause on click
            $fotorama.off('click.videoControl').on('click.videoControl', '.video_control', function (e) {
                e.stopPropagation();
                
                var $activeFrame = $('.fotorama__active');
                var $container = $activeFrame.find('.fotorama-video-container');
                var videoTag = $activeFrame.find('#video-tag').get(0);
                
                if (videoTag) {
                    if (videoTag.paused) {
                        // Play video
                        $container.css("opacity", "1");
                        videoTag.setAttribute('controls', true);
                        videoTag.play().catch(function(error) {
                            console.warn('Video play failed:', error);
                        });
                    } else {
                        // Pause video
                        videoTag.pause();
                        videoTag.currentTime = 0;
                        $container.css("opacity", "0.5");
                        videoTag.removeAttribute('controls');
                    }
                }
            });

            isVideoInitialized = true;
        }

        // Initialize when document is ready
        $(document).ready(function () {
            // Listen for gallery loaded event
            $(document).on('gallery:loaded', function () {
                setTimeout(initializeVideoGallery, 100);
            });

            // Also try to initialize immediately if gallery is already loaded
            setTimeout(initializeVideoGallery, 1000);
        });

        // Handle fullscreen changes
        $(document).on('fullscreenchange webkitfullscreenchange mozfullscreenchange', function() {
            var videoTag = $('.fotorama__active #video-tag').get(0);
            if (videoTag && !document.fullscreenElement) {
                videoTag.pause();
                videoTag.currentTime = 0;
                var $container = $('.fotorama__active .fotorama-video-container');
                if ($container.length) {
                    $container.css("opacity", "0.5");
                    videoTag.removeAttribute('controls');
                }
            }
        });

    });
</script>